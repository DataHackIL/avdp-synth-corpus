{
  "turns": [
    {
      "emotional_state": "calm",
      "intensity": 1,
      "pause_before_s": 0.0,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05de\u05d4 \u05d9\u05e9 \u05dc\u05d0\u05db\u05d5\u05dc? \u05e2\u05e9\u05d9\u05ea \u05de\u05e9\u05d4\u05d5 \u05dc\u05d0\u05e8\u05d5\u05d7\u05ea \u05e2\u05e8\u05d1?"
    },
    {
      "emotional_state": "neutral",
      "intensity": 1,
      "pause_before_s": 0.4,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05db\u05df, \u05e2\u05e9\u05d9\u05ea\u05d9 \u05d0\u05d5\u05e8\u05d6 \u05e2\u05dd \u05e2\u05d5\u05e3. \u05e2\u05d5\u05d3 \u05e8\u05d2\u05e2 \u05de\u05d5\u05db\u05df."
    },
    {
      "emotional_state": "calm",
      "intensity": 2,
      "pause_before_s": 1.2,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05d0\u05d4, \u05d9\u05d5\u05e4\u05d9. \u05d0\u05d2\u05d1, \u05d3\u05d9\u05d1\u05e8\u05ea\u05d9 \u05e2\u05dd \u05d0\u05de\u05d0 \u05e9\u05dc\u05d9 \u05d4\u05d9\u05d5\u05dd, \u05d4\u05d9\u05d0 \u05d0\u05de\u05e8\u05d4 \u05e9\u05e8\u05d0\u05ea\u05d4 \u05d0\u05d5\u05ea\u05da \u05d1\u05e8\u05d7\u05d5\u05d1 \u05d4\u05d9\u05d5\u05dd \u05d0\u05d7\u05e8\u05d9 \u05d4\u05e6\u05d4\u05e8\u05d9\u05d9\u05dd. \u05d0\u05d9\u05e4\u05d4 \u05d4\u05d9\u05d9\u05ea?"
    },
    {
      "emotional_state": "neutral",
      "intensity": 2,
      "pause_before_s": 0.8,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d0\u05d4... \u05d9\u05e6\u05d0\u05ea\u05d9 \u05dc\u05e7\u05e0\u05d5\u05ea \u05db\u05de\u05d4 \u05d3\u05d1\u05e8\u05d9\u05dd. \u05d7\u05e1\u05e8 \u05dc\u05e0\u05d5 \u05db\u05de\u05d4 \u05d3\u05d1\u05e8\u05d9\u05dd \u05dc\u05de\u05d8\u05d1\u05d7."
    },
    {
      "emotional_state": "angry",
      "intensity": 2,
      "pause_before_s": 0.5,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05dc\u05e7\u05e0\u05d5\u05ea \u05db\u05de\u05d4 \u05d3\u05d1\u05e8\u05d9\u05dd? \u05d0\u05de\u05d0 \u05e9\u05dc\u05d9 \u05d0\u05de\u05e8\u05d4 \u05e9\u05e8\u05d0\u05ea\u05d4 \u05d0\u05d5\u05ea\u05da \u05e2\u05dd \u05de\u05d9\u05e9\u05d4\u05d9 \u05dc\u05d9\u05d3 \u05d4\u05e7\u05e0\u05d9\u05d5\u05df. \u05dc\u05d0 \u05dc\u05d9\u05d3 \u05d4\u05de\u05db\u05d5\u05dc\u05ea. \u05d0\u05ea \u05e8\u05d5\u05e6\u05d4 \u05dc\u05e1\u05e4\u05e8 \u05dc\u05d9 \u05de\u05d4 \u05d1\u05d0\u05de\u05ea \u05e2\u05e9\u05d9\u05ea?"
    },
    {
      "emotional_state": "fearful",
      "intensity": 2,
      "pause_before_s": 0.6,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05e0\u05e4\u05d2\u05e9\u05ea\u05d9 \u05e2\u05dd \u05e9\u05e8\u05d5\u05df \u05dc\u05d7\u05e6\u05d9 \u05e9\u05e2\u05d4 \u05dc\u05e7\u05e4\u05d4, \u05d6\u05d4 \u05d4\u05db\u05dc. \u05dc\u05d0 \u05d7\u05e9\u05d1\u05ea\u05d9 \u05e9\u05d6\u05d4 \u05de\u05e9\u05d4\u05d5..."
    },
    {
      "emotional_state": "angry",
      "intensity": 3,
      "pause_before_s": 0.3,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05dc\u05d0 \u05d7\u05e9\u05d1\u05ea \u05e9\u05d6\u05d4 \u05de\u05e9\u05d4\u05d5? \u05d0\u05e0\u05d9 \u05e2\u05d5\u05d1\u05d3 \u05db\u05dc \u05d4\u05d9\u05d5\u05dd \u05db\u05de\u05d5 \u05db\u05dc\u05d1 \u05d5\u05d0\u05ea \u05de\u05e1\u05ea\u05d5\u05d1\u05d1\u05ea \u05d1\u05d7\u05d5\u05e5 \u05d1\u05dc\u05d9 \u05dc\u05d4\u05d2\u05d9\u05d3 \u05dc\u05d9 \u05de\u05d9\u05dc\u05d4? \u05de\u05d4, \u05d0\u05e0\u05d9 \u05dc\u05d0 \u05e7\u05d9\u05d9\u05dd? \u05e1\u05d9\u05db\u05de\u05e0\u05d5 \u05e9\u05d0\u05ea \u05de\u05e2\u05d3\u05db\u05e0\u05ea \u05d0\u05d5\u05ea\u05d9 \u05db\u05e9\u05d0\u05ea \u05d9\u05d5\u05e6\u05d0\u05ea \u05de\u05d4\u05d1\u05d9\u05ea."
    },
    {
      "emotional_state": "pleading",
      "intensity": 3,
      "pause_before_s": 0.7,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d0\u05ea\u05d4 \u05e6\u05d5\u05d3\u05e7, \u05d4\u05d9\u05d9\u05ea\u05d9 \u05e6\u05e8\u05d9\u05db\u05d4 \u05dc\u05d4\u05d2\u05d9\u05d3 \u05dc\u05da. \u05e1\u05dc\u05d9\u05d7\u05d4. \u05d6\u05d4 \u05d1\u05d0\u05de\u05ea \u05d4\u05d9\u05d4 \u05e1\u05ea\u05dd \u05e7\u05e4\u05d4 \u05e7\u05e6\u05e8."
    },
    {
      "emotional_state": "threatening",
      "intensity": 4,
      "pause_before_s": 0.4,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05e1\u05ea\u05dd \u05e7\u05e4\u05d4 \u05e7\u05e6\u05e8. \u05ea\u05de\u05d9\u05d3 \u05d9\u05e9 \u05dc\u05da \u05ea\u05d9\u05e8\u05d5\u05e6\u05d9\u05dd. \u05d0\u05ea \u05d9\u05d5\u05d3\u05e2\u05ea \u05de\u05d4? \u05d0\u05e0\u05d9 \u05dc\u05d0 \u05de\u05d0\u05de\u05d9\u05df \u05dc\u05da. \u05ea\u05e0\u05d9 \u05dc\u05d9 \u05d0\u05ea \u05d4\u05d8\u05dc\u05e4\u05d5\u05df \u05e9\u05dc\u05da. \u05e2\u05db\u05e9\u05d9\u05d5. \u05d0\u05e0\u05d9 \u05e8\u05d5\u05e6\u05d4 \u05dc\u05e8\u05d0\u05d5\u05ea \u05e2\u05dd \u05de\u05d9 \u05d3\u05d9\u05d1\u05e8\u05ea \u05d4\u05d9\u05d5\u05dd."
    },
    {
      "emotional_state": "fearful",
      "intensity": 4,
      "pause_before_s": 0.9,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d1\u05d1\u05e7\u05e9\u05d4, \u05d0\u05dc \u05ea\u05e2\u05e9\u05d4 \u05d0\u05ea \u05d6\u05d4 \u05e9\u05d5\u05d1... \u05d0\u05ea\u05d4 \u05d9\u05db\u05d5\u05dc \u05dc\u05d1\u05d3\u05d5\u05e7, \u05d0\u05d9\u05df \u05dc\u05d9 \u05de\u05d4 \u05dc\u05d4\u05e1\u05ea\u05d9\u05e8. \u05d0\u05e0\u05d9 \u05e8\u05e7 \u05de\u05d1\u05e7\u05e9\u05ea \u05e9\u05dc\u05d0 \u05ea\u05e6\u05e2\u05e7."
    },
    {
      "emotional_state": "threatening",
      "intensity": 5,
      "pause_before_s": 0.3,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05d0\u05e0\u05d9 \u05d0\u05e6\u05e2\u05e7 \u05db\u05de\u05d4 \u05e9\u05d1\u05d0 \u05dc\u05d9 \u05d1\u05d1\u05d9\u05ea \u05e9\u05dc\u05d9. \u05ea\u05e9\u05de\u05e2\u05d9 \u05d0\u05d5\u05ea\u05d9 \u05d8\u05d5\u05d1 \u2014 \u05de\u05d4\u05d9\u05d5\u05dd \u05d0\u05ea \u05dc\u05d0 \u05d9\u05d5\u05e6\u05d0\u05ea \u05de\u05d4\u05d3\u05d9\u05e8\u05d4 \u05d4\u05d6\u05d0\u05ea \u05d1\u05dc\u05d9 \u05e9\u05d0\u05e0\u05d9 \u05d9\u05d5\u05d3\u05e2 \u05dc\u05d0\u05df, \u05e2\u05dd \u05de\u05d9, \u05d5\u05dc\u05de\u05d4. \u05d5\u05d0\u05dd \u05d0\u05e0\u05d9 \u05e9\u05d5\u05de\u05e2 \u05e9\u05d5\u05d1 \u05e9\u05d0\u05ea \u05e0\u05e4\u05d2\u05e9\u05ea \u05e2\u05dd \u05de\u05d9\u05e9\u05d4\u05d5 \u05de\u05d0\u05d7\u05d5\u05e8\u05d9 \u05d4\u05d2\u05d1 \u05e9\u05dc\u05d9, \u05d0\u05e0\u05d9 \u05d0\u05d3\u05d0\u05d2 \u05e9\u05dc\u05d0 \u05ea\u05e8\u05d0\u05d9 \u05d0\u05e3 \u05d0\u05d7\u05d3 \u05d9\u05d5\u05ea\u05e8. \u05d1\u05e8\u05d5\u05e8?"
    },
    {
      "emotional_state": "fearful",
      "intensity": 5,
      "pause_before_s": 1.5,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d1\u05e8\u05d5\u05e8... \u05d1\u05e8\u05d5\u05e8. \u05d0\u05e0\u05d9 \u05de\u05d1\u05d9\u05e0\u05d4. \u05d6\u05d4 \u05dc\u05d0 \u05d9\u05e7\u05e8\u05d4 \u05e9\u05d5\u05d1."
    }
  ]
}
