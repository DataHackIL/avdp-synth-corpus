{
  "turns": [
    {
      "emotional_state": "angry",
      "intensity": 2,
      "pause_before_s": 0.0,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05de\u05d4 \u05d6\u05d4 \u05d4\u05d0\u05e8\u05d5\u05d7\u05d4 \u05d4\u05d6\u05d0\u05ea? \u05e9\u05d0\u05dc\u05ea\u05d9 \u05d0\u05d5\u05ea\u05da \u05d3\u05d1\u05e8 \u05d0\u05d7\u05d3 \u05e4\u05e9\u05d5\u05d8, \u05dc\u05e2\u05e9\u05d5\u05ea \u05d0\u05e8\u05d5\u05d7\u05ea \u05e2\u05e8\u05d1 \u05e0\u05d5\u05e8\u05de\u05dc\u05d9\u05ea. \u05d6\u05d4 \u05d9\u05d5\u05ea\u05e8 \u05de\u05d3\u05d9 \u05d1\u05e9\u05d1\u05d9\u05dc\u05da?"
    },
    {
      "emotional_state": "neutral",
      "intensity": 2,
      "pause_before_s": 0.8,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05e2\u05d1\u05d3\u05ea\u05d9 \u05e2\u05d3 \u05e9\u05e9 \u05d4\u05d9\u05d5\u05dd. \u05e2\u05e9\u05d9\u05ea\u05d9 \u05de\u05d4 \u05e9\u05d4\u05e1\u05e4\u05e7\u05ea\u05d9. \u05d0\u05dd \u05d6\u05d4 \u05dc\u05d0 \u05de\u05e1\u05e4\u05d9\u05e7 \u05d8\u05d5\u05d1, \u05d0\u05ea\u05d4 \u05de\u05d5\u05d6\u05de\u05df \u05dc\u05d1\u05e9\u05dc \u05d1\u05e2\u05e6\u05de\u05da."
    },
    {
      "emotional_state": "angry",
      "intensity": 3,
      "pause_before_s": 0.3,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05d0\u05d4, \u05e2\u05db\u05e9\u05d9\u05d5 \u05d2\u05dd \u05d7\u05d5\u05e6\u05e4\u05d4? \u05d0\u05e0\u05d9 \u05e2\u05d5\u05d1\u05d3 \u05e9\u05ea\u05d9\u05dd \u05e2\u05e9\u05e8\u05d4 \u05e9\u05e2\u05d5\u05ea \u05d1\u05d9\u05d5\u05dd \u05d5\u05d0\u05ea \u05dc\u05d0 \u05de\u05e1\u05d5\u05d2\u05dc\u05ea \u05dc\u05e2\u05e9\u05d5\u05ea \u05d3\u05d1\u05e8 \u05d0\u05d7\u05d3 \u05db\u05de\u05d5 \u05e9\u05e6\u05e8\u05d9\u05da. \u05d3\u05d1\u05e8 \u05d0\u05d7\u05d3. \u05ea\u05de\u05d9\u05d3 \u05db\u05db\u05d4 \u05d0\u05d9\u05ea\u05da."
    },
    {
      "emotional_state": "angry",
      "intensity": 3,
      "pause_before_s": 0.5,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05dc\u05de\u05d4 \u05d0\u05ea\u05d4 \u05ea\u05de\u05d9\u05d3 \u05e6\u05e8\u05d9\u05da \u05dc\u05d4\u05e7\u05d8\u05d9\u05df \u05d0\u05ea \u05de\u05d4 \u05e9\u05d0\u05e0\u05d9 \u05e2\u05d5\u05e9\u05d4? \u05d2\u05dd \u05d0\u05e0\u05d9 \u05e2\u05d5\u05d1\u05d3\u05ea, \u05d2\u05dd \u05d0\u05e0\u05d9 \u05e2\u05d9\u05d9\u05e4\u05d4. \u05d0\u05ea\u05d4 \u05d0\u05e3 \u05e4\u05e2\u05dd \u05dc\u05d0 \u05de\u05e8\u05d5\u05e6\u05d4."
    },
    {
      "emotional_state": "angry",
      "intensity": 4,
      "pause_before_s": 0.2,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05db\u05d9 \u05d0\u05ea \u05dc\u05d0 \u05e2\u05d5\u05e9\u05d4 \u05db\u05dc\u05d5\u05dd! \u05ea\u05e1\u05ea\u05db\u05dc\u05d9 \u05e2\u05dc \u05d4\u05d1\u05d9\u05ea \u05d4\u05d6\u05d4, \u05ea\u05e1\u05ea\u05db\u05dc\u05d9 \u05e2\u05dc \u05e2\u05e6\u05de\u05da. \u05d1\u05d5\u05e9\u05d4. \u05d0\u05de\u05d0 \u05e9\u05dc\u05d9 \u05e6\u05d3\u05e7\u05d4 \u05dc\u05d2\u05d1\u05d9\u05da, \u05d0\u05ea \u05dc\u05d0 \u05e9\u05d5\u05d5\u05d4 \u05db\u05dc\u05d5\u05dd."
    },
    {
      "emotional_state": "fearful",
      "intensity": 3,
      "pause_before_s": 0.4,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d0\u05dc \u05ea\u05d3\u05d1\u05e8 \u05db\u05db\u05d4 \u05d0\u05dc\u05d9\u05d9. \u05d0\u05e0\u05d9 \u05de\u05d1\u05e7\u05e9\u05ea \u05de\u05de\u05da, \u05ea\u05e4\u05e1\u05d9\u05e7. \u05d0\u05dc \u05ea\u05db\u05e0\u05d9\u05e1 \u05d0\u05ea \u05d0\u05de\u05d0 \u05e9\u05dc\u05da \u05dc\u05d6\u05d4."
    },
    {
      "emotional_state": "threatening",
      "intensity": 4,
      "pause_before_s": 0.1,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05de\u05d4, \u05e2\u05db\u05e9\u05d9\u05d5 \u05d0\u05ea \u05ea\u05d2\u05d9\u05d3\u05d9 \u05dc\u05d9 \u05de\u05d4 \u05dc\u05e2\u05e9\u05d5\u05ea? \u05d0\u05ea \u05ea\u05d2\u05d9\u05d3\u05d9 \u05dc\u05d9? \u05d0\u05e0\u05d9 \u05de\u05d6\u05d4\u05d9\u05e8 \u05d0\u05d5\u05ea\u05da, \u05ea\u05e1\u05ea\u05de\u05d9 \u05e2\u05db\u05e9\u05d9\u05d5. \u05ea\u05e1\u05ea\u05de\u05d9 \u05d0\u05ea \u05d4\u05e4\u05d4."
    },
    {
      "emotional_state": "pleading",
      "intensity": 4,
      "pause_before_s": 0.6,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d0\u05ea\u05d4 \u05de\u05e4\u05d7\u05d9\u05d3 \u05d0\u05d5\u05ea\u05d9 \u05db\u05e9\u05d0\u05ea\u05d4 \u05db\u05db\u05d4. \u05d1\u05d1\u05e7\u05e9\u05d4, \u05d1\u05d5\u05d0 \u05e0\u05d9\u05e7\u05d7 \u05d0\u05d5\u05d5\u05d9\u05e8, \u05d1\u05d5\u05d0 \u05e0\u05d9\u05e8\u05d2\u05e2..."
    },
    {
      "emotional_state": "threatening",
      "intensity": 5,
      "pause_before_s": 0.1,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05e9\u05ea\u05e7\u05ea\u05d9! \u05d0\u05de\u05e8\u05ea\u05d9 \u05dc\u05da \u05ea\u05e9\u05ea\u05e7\u05d9!"
    },
    {
      "emotional_state": "fearful",
      "intensity": 5,
      "pause_before_s": 0.2,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d0\u05d0\u05d0! \u05dc\u05d0! \u05e2\u05d6\u05d5\u05d1 \u05d0\u05d5\u05ea\u05d9! \u05db\u05d5\u05d0\u05d1 \u05dc\u05d9! \u05db\u05d5\u05d0\u05d1!"
    },
    {
      "emotional_state": "threatening",
      "intensity": 5,
      "pause_before_s": 0.3,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05ea\u05dc\u05de\u05d3\u05d9 \u05dc\u05e9\u05ea\u05d5\u05e7 \u05db\u05e9\u05d0\u05e0\u05d9 \u05de\u05d3\u05d1\u05e8. \u05e9\u05de\u05e2\u05ea \u05d0\u05d5\u05ea\u05d9?"
    },
    {
      "emotional_state": "pleading",
      "intensity": 4,
      "pause_before_s": 0.7,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d1\u05d1\u05e7\u05e9\u05d4... \u05ea\u05e4\u05e1\u05d9\u05e7... \u05d0\u05e0\u05d9 \u05dc\u05d0... \u05d0\u05e0\u05d9 \u05dc\u05d0 \u05d9\u05db\u05d5\u05dc\u05d4 \u05dc\u05e0\u05e9\u05d5\u05dd..."
    },
    {
      "emotional_state": "calm",
      "intensity": 2,
      "pause_before_s": 1.5,
      "speaker_id": "AGG_M_30-45_001",
      "text": "\u05ea\u05e4\u05e1\u05d9\u05e7\u05d9 \u05dc\u05d1\u05db\u05d5\u05ea. \u05d0\u05ea \u05e2\u05d5\u05e9\u05d4 \u05de\u05d6\u05d4 \u05e2\u05e0\u05d9\u05d9\u05df \u05e9\u05dc \u05de\u05d4 \u05d1\u05db\u05da. \u05dc\u05d0 \u05e2\u05e9\u05d9\u05ea\u05d9 \u05dc\u05da \u05e9\u05d5\u05dd \u05d3\u05d1\u05e8. \u05d0\u05ea \u05ea\u05de\u05d9\u05d3 \u05de\u05d2\u05d6\u05d9\u05de\u05d4, \u05ea\u05de\u05d9\u05d3."
    },
    {
      "emotional_state": "sad",
      "intensity": 2,
      "pause_before_s": 1.2,
      "speaker_id": "VIC_F_25-40_002",
      "text": "\u05d4\u05d9\u05d3 \u05e9\u05dc\u05d9... \u05d4\u05db\u05d0\u05ea \u05d0\u05d5\u05ea\u05d9... \u05dc\u05de\u05d4..."
    }
  ]
}
